### dev ###
# It’s common to separate images for different purposes (build, dev, runtime).
# You can do this with:
#   - multiple Dockerfiles, each building its own image, or
#   - a single Dockerfile with multiple build stages (multiple FROM lines)
#     then choose which stage to build using `--target`
# This stage reuses everything from the `build` stage and adds dev tools
FROM build AS dev 

### change user ###
# TODO
# set the username as "ubuntu"
# you can reference the Dockerfile from TECHIN 516, or ros2 humble Dockerfiles from ijnek
# https://github.com/GIXLabs/TECHIN516/blob/main/turtlebot4_ws/.devcontainer/Dockerfile

RUN sudo apt-get update && sudo apt-get install -y --no-install-recommends \
    vim \
    nano \
    less \
    tmux

RUN echo "export PATH=\"$HOME/.local/bin:$PATH\"" >> /home/ubuntu/.bashrc && \
    echo "source /opt/ros/humble/setup.bash" >> /home/ubuntu/.bashrc  && \
    echo "source /home/ubuntu/techin517/so101_ws/install/setup.bash" >> /home/ubuntu/.bashrc && \
    echo "export ROS_LOCALHOST_ONLY=1" >> /home/ubuntu/.bashrc && \
    echo "export LEROBOT_SRC=\"/home/ubuntu/techin517/third_party/lerobot/src/lerobot\"" >> /home/ubuntu/.bashrc && \
    echo "export SO101BRIDGE_INSTALL_SITE_PACKAGES=\"/home/ubuntu/techin517/so101_ws/install/so101_ros2_bridge/lib/python3.10/site-packages/lerobot\"" >> /home/ubuntu/.bashrc

# Default shell
CMD ["/bin/bash"]

