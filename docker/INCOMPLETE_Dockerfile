### ros setup ###
# rosdep update
RUN rosdep update
# .bashrc ROS settings
RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> ~/.bashrc
RUN echo "source /home/ubuntu/techin517/so101_ws/install/setup.bash" >> ~/.bashrc
RUN echo "export ROS_LOCALHOST_ONLY=1" >> ~/.bashrc
RUN echo "export LECONDA_SITE_PACKAGES=\"/home/ubuntu/miniconda3/envs/lerobot_ros2/lib/python3.10/site-packages\"" >> ~/.bashrc
RUN echo "export LEROBOT_SRC=\"/home/ubuntu/techin517/third_party/lerobot/src/lerobot\"" >> ~/.bashrc
RUN echo "export SO101BRIDGE_INSTALL_SITE_PACKAGES=\"/home/ubuntu/techin517/so101_ws/install/so101_ros2_bridge/lib/python3.10/site-packages/lerobot\"" >> ~/.bashrc

CMD ["bash"]

